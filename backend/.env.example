# ===========================================
# ARProperty 백엔드 환경변수 설정
# ===========================================
# 이 파일을 복사하여 .env 파일을 만드세요:
#   cp .env.example .env
# 그리고 실제 API 키를 입력하세요.
# .env 파일은 절대 git에 커밋하지 마세요!

# --- Database ---
DATABASE_URL=postgresql://arproperty:devpassword@localhost:5432/arproperty

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- 공공데이터포털 API 키 (data.go.kr) ---
# https://www.data.go.kr 에서 발급
# 건축물대장정보, 아파트 매매 실거래가, 공동주택 단지 목록 3개 서비스 활용신청 필요
DATA_GO_KR_API_KEY=your_api_key_here

# --- 브이월드 API 키 (vworld.kr) ---
# https://www.vworld.kr/dev/ 에서 발급
VWORLD_API_KEY=your_vworld_key_here

# --- Kakao REST API 키 ---
# https://developers.kakao.com 에서 발급
KAKAO_REST_API_KEY=your_kakao_key_here

# --- 구미시 코드 (변경 불필요) ---
GUMI_SIGUNGU_CD=47190
